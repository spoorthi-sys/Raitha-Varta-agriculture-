{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.apk",
        "headers": [
          {
            "key": "Content-Disposition",
            "value": "attachment; filename=\"Raitha_Varta.apk\""
          }
        ]
      }
    ]
  }
}
